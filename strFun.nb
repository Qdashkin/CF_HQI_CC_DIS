Cell["Load storage file", "Chapter",ExpressionUUID->"e51f70a8-7473-473a-bb53-31b5adab4bac"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"d6d57742-06f6-4c11-8233-70b8b806608f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Get", "[", "\"\<strFun.mx\>\"", "]"}], ";"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"db7a8060-4ec6-4618-aca1-c2a877addf5a"],

Cell["Rule to replace the variable u with its definition:", "Text",ExpressionUUID->"b9532ff3-7a9b-49bb-a542-bf68c1b59583"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ruleU", "=", 
   RowBox[{"{", 
    RowBox[{"u", "\[Rule]", 
     RowBox[{"Sqrt", "[", 
      FractionBox["y1", 
       RowBox[{"y1", "-", 
        RowBox[{"4", "y2"}]}]], "]"}]}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"3ebc1051-ecfa-4cdd-9b63-62cbb8a9f9df"],

Cell["The leading order result:", "Text",ExpressionUUID->"051201cb-b520-47b8-b61b-968b9d13080f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"loResult", "=", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["Splus", "2"], ",", 
     FractionBox[
      RowBox[{"Splus", " ", "xBj"}], 
      RowBox[{"1", "-", "y2"}]], ",", 
     RowBox[{"2", " ", "Rplus"}]}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"d091d4b1-29ed-4384-95d3-e41c34411f84"],

Cell["The zeta values", "Text",ExpressionUUID->"c235b3b3-2231-42ca-a989-ad7fa1c59b79"],

Cell[BoxData[
 RowBox[{"zetaValues", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"zeta2", "\[Rule]", 
     FractionBox[
      SuperscriptBox["\[Pi]", "2"], "6"]}], ",", 
    RowBox[{"zeta3", "\[Rule]", 
     RowBox[{"Zeta", "[", "3", "]"}]}], ",", 
    RowBox[{"zeta4", "\[Rule]", 
     FractionBox[
      SuperscriptBox["\[Pi]", "4"], "90"]}]}], "}"}]}]], "Input",ExpressionUUI\
D->"acdde36a-1369-4ee2-9360-6593b728743f"]
}, Closed]],

Cell[CellGroupData[{

Cell["Coefficient Function", "Chapter",ExpressionUUID->"820a692a-dded-4cfe-a8b2-53823b3c9f2d"],

Cell["\<\
There are some minor differences with the publication: 
1)The indices of the coefficient functions differ,\[LineSeparator]2) we do \
not present rules for soft-singular coefficients separately, but only the \
rules for the color coefficients.\
\>", "Text",ExpressionUUID->"fa8563a9-a308-4e15-a34a-9bd235f01e16"],

Cell[CellGroupData[{

Cell[TextData[{
 "Results at ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Mu]", "R", "2"], "=", 
    RowBox[{
     SubsuperscriptBox["\[Mu]", "F", "2"], "=", 
     SuperscriptBox["Q", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "04e50bf1-58ba-45d0-a413-1d77d90553c4"]
}], "Section",ExpressionUUID->"35795a2b-2fb6-498a-9406-4e77d8d10dbb"],

Cell["The total C_1, C_2 and C_3 coefficient functions", "Text",ExpressionUUID->"745583bb-b6a7-4d7e-b36d-5f8213c1858a"],

Cell[BoxData["totalPartonicCoefficientFunction"], "Input",ExpressionUUID->"356dacf6-e30e-4ab6-adde-b6d898e66278"],

Cell[TextData[{
 "LL - Light coefficient rules (only light flavors in the final state): LL= \
LL[i,j,k]. \nHere, i = 1, 2, 3 is the index of coefficient function,\nj \
=0,1,2 perturbative order,\nk = 1,...,4, the color structure ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SuperscriptBox["cF", "2"], ",", 
    RowBox[{"cF", " ", "cA"}], " ", ",", 
    RowBox[{"nL", " ", "cF"}], ",", 
    RowBox[{"nH", " ", "cF"}]}], " ", "}"}]], "Input",
  CellChangeTimes->{{3.9765064589227877`*^9, 3.976506490092719*^9}, {
   3.976506533376707*^9, 3.976506544109962*^9}},ExpressionUUID->
  "8c2badb0-cd5b-4ad1-ba25-9e9824619688"],
 ".\[LineSeparator]For light coefficient functions, only W^-+c - channel is \
not zero (modulo charge symmetry)"
}], "Text",ExpressionUUID->"942739b3-f260-44c2-9704-4115cae5abd9"],

Cell[BoxData["LLCoefRules"], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"5cbfb115-0c0e-4ac9-8ce6-dc6cf566acb1"],

Cell[TextData[{
 "HH-heavy coefficient rules (two heavy flavors in the final state):  H= \
H[i,j,k,l]\nHere, i = 1,2,3 is the index of heavy coefficient function,\nj = \
2 perturbative order,\nk = 1,...,3, the color structure ",
 Cell[BoxData[
  RowBox[{"{", " ", 
   RowBox[{
    RowBox[{"cF", 
     RowBox[{"(", 
      RowBox[{"cF", "-", 
       FractionBox["cA", "2"]}], ")"}]}], ",", "cF", ",", 
    RowBox[{"nH", " ", "cF"}]}], " ", "}"}]], "Input",
  CellChangeTimes->{{3.9765064589227877`*^9, 3.976506490092719*^9}, {
   3.976506533376707*^9, 3.976506544109962*^9}},ExpressionUUID->
  "b81286b7-b28d-4423-b00d-7e72d8b042fc"],
 "\nl =  1-> heavy quark,   2 ->heavy antiquark initiated DIS. "
}], "Text",ExpressionUUID->"3280a3d4-c79a-47e0-8230-d6e716da8d15"],

Cell[BoxData["HHCoefRules"], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"592b7fbd-4331-4535-9553-d1d55ea04eeb"],

Cell[TextData[{
 "KK - heavy coefficient rules (one heavy flavor in the final state):  KK= \
KK[i,j,k,l]\nHere, i = 1,2,3 is the index of heavy coefficient function,\nj = \
2 perturbative order,\nk = 1, the color structure ",
 Cell[BoxData[
  RowBox[{"{", "cF", "}"}]], "Input",
  CellChangeTimes->{{3.9765064589227877`*^9, 3.976506490092719*^9}, {
   3.976506533376707*^9, 3.976506544109962*^9}},ExpressionUUID->
  "93c3ae05-9fdd-4dba-828b-382cfde7c644"],
 "\nl =  1-> heavy quark,   2 ->heavy antiquark initiated DIS. "
}], "Text",ExpressionUUID->"ff7f2564-df33-4a5e-a115-0b536622e21c"],

Cell[BoxData["KKCoefRules"], "Input",ExpressionUUID->"c3f33690-ba94-4b25-8455-04f1f415c6b5"],

Cell["\<\
mapIteratedIntegrals contains mappings of iterated integrals to Goncharov \
polylogarithms\
\>", "Text",ExpressionUUID->"0ace55c0-6a2b-4861-9266-674ef789e874"],

Cell[BoxData["mapIteratedIntegrals"], "Input",
 CellLabel->"",ExpressionUUID->"2435b282-243b-4715-80c4-662fb242ac32"],

Cell[TextData[{
 "To obtain the coefficient functions at ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "R"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "94359d98-2f04-472b-ac86-90d77e4df966"],
 "=Q , simply use:"
}], "Text",ExpressionUUID->"0feda23e-03b8-446f-843a-956dfe435f8a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"strFuns", "=", 
   RowBox[{"(*", "loResult", "*)"}], " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"totalPartonicCoefficientFunction", "/.", "LLCoefRules"}], "/.",
        "HHCoefRules"}], "/.", "KKCoefRules"}], "/.", 
     "mapIteratedIntegrals"}], "/.", "ruleU"}]}], ";"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"1aa2d0c8-c73d-4410-8034-40591065c8a8"],

Cell[TextData[{
 "By default, the coefficient functions include the IR counter-term \
(Eq.~(4.15) from the corresponding paper. To remove it,\[LineSeparator]simply \
reverse the regularization, i.e. add back the  naive Taylor expansion and \
subtract the asymptotic expansion in the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], "\[Rule]", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "4402f9d9-3758-485a-a8a8-de610e6410c6"],
 " limit\[LineSeparator](see \[OpenCurlyDoubleQuote]Heavy infrared counter \
term below\[CloseCurlyDoubleQuote])."
}], "Text",ExpressionUUID->"8dcfc6ef-c650-4840-b8a5-00355bf255e1"]
}, Closed]],

Cell[CellGroupData[{

Cell["Restoring the scale dependence", "Section",ExpressionUUID->"3f171786-3484-4848-a9d1-71dcf230a8f4"],

Cell["\<\
Here, we reproduce Eq.~(4.8) from the corresponding paper in the decoupling \
scheme.\
\>", "Text",ExpressionUUID->"d2b20f9e-15d8-422a-ba4c-71856b591f65"],

Cell[BoxData[{
 RowBox[{"totalPartonicCoefficientFunction", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"totalPartonicCoefficientFunctionmu", "=", 
   RowBox[{"%", "+", 
    RowBox[{
     SuperscriptBox["\[Alpha]r", "2"], " ", 
     RowBox[{"Log", "[", 
      FractionBox[
       SuperscriptBox["\[Mu]R", "2"], 
       SuperscriptBox["Q", "2"]], "]"}], 
     RowBox[{"(", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         FractionBox["11", "6"], "cA"}], "-", 
        RowBox[{
         FractionBox["4", "12"], " ", "nL"}]}], ")"}], ")"}], 
     RowBox[{"Coefficient", "[", 
      RowBox[{"%", ",", "\[Alpha]r", ",", "1"}], "]"}]}]}]}], 
  RowBox[{"(*", 
   RowBox[{"/.", "LCoefRules"}], "*)"}], ";"}]}], "Input",ExpressionUUID->\
"76fb20c1-ae59-479d-9f8e-ff03faa39e79"]
}, Closed]],

Cell[CellGroupData[{

Cell["HH-Heavy infrared counter term", "Section",ExpressionUUID->"59060e30-ddd6-4438-8680-e2af0b4c2fc1"],

Cell["\<\
The IR counter term is universal for C_1, C_2 and C_3 coefficient functions. \
It is consists of two parts:\[LineSeparator]Taylor expansion\
\>", "Text",ExpressionUUID->"6ebcf9ee-cdf4-4ea9-b5e8-e57d7080693a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"heavyIRCTTaylo", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      FractionBox["359", 
       RowBox[{"108", " ", "y1"}]], "-", 
      FractionBox[
       RowBox[{"2", " ", "zeta2"}], 
       RowBox[{"3", " ", "y1"}]], "+", 
      FractionBox[
       SuperscriptBox[
        RowBox[{"Log", "[", "y1", "]"}], "2"], 
       RowBox[{"3", " ", "y1"}]], "+", 
      FractionBox[
       RowBox[{"29", " ", 
        RowBox[{"Log", "[", "y2", "]"}]}], 
       RowBox[{"18", " ", "y1"}]], "+", 
      FractionBox[
       SuperscriptBox[
        RowBox[{"Log", "[", "y2", "]"}], "2"], 
       RowBox[{"3", " ", "y1"}]], "+", 
      RowBox[{
       RowBox[{"Log", "[", "y1", "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["29", 
           RowBox[{"18", " ", "y1"}]]}], "-", 
         FractionBox[
          RowBox[{"2", " ", 
           RowBox[{"Log", "[", "y2", "]"}]}], 
          RowBox[{"3", " ", "y1"}]]}], ")"}]}]}], ")"}], 
    SuperscriptBox["\[Alpha]r", "2"], "cF", " ", "nH", " ", 
    RowBox[{"TAG", "[", "wmq1", "]"}]}]}], ";"}]], "Input",ExpressionUUID->\
"d2936ba1-6516-44bb-b6c1-eedbd66bd212"],

Cell["Asymptotic expansion", "Text",ExpressionUUID->"ac47622b-a7fd-4520-8be1-bbe579b97f43"],

Cell[BoxData[
 RowBox[{
  RowBox[{"heavyIRCTAsymptotic", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", 
             FractionBox["359", "54"]}], "+", 
            FractionBox[
             RowBox[{"4", " ", "zeta2"}], "3"]}], ")"}], " ", 
          RowBox[{"Log", "[", "2", "]"}]}], "+", 
         FractionBox[
          RowBox[{"29", " ", 
           SuperscriptBox[
            RowBox[{"Log", "[", "2", "]"}], "2"]}], "9"], "-", 
         FractionBox[
          RowBox[{"8", " ", 
           SuperscriptBox[
            RowBox[{"Log", "[", "2", "]"}], "3"]}], "9"], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", 
             FractionBox["359", "108"]}], "+", 
            FractionBox[
             RowBox[{"2", " ", "zeta2"}], "3"]}], ")"}], " ", 
          RowBox[{"Log", "[", "y2", "]"}]}], "-", 
         FractionBox[
          RowBox[{"29", " ", 
           SuperscriptBox[
            RowBox[{"Log", "[", "y2", "]"}], "2"]}], "36"], "-", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"Log", "[", "y2", "]"}], "3"], "9"]}], ")"}], " ", 
       RowBox[{"PD", "[", "0", "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
